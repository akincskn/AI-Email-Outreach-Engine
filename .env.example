# ==============================================================
# AI Email Outreach Engine — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or .env to version control.
# ==============================================================

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=

# --- AI Providers (production için ZORUNLU — Görev 5'te gerçek mail üretilir) ---
GROQ_API_KEY=          # mock yerine gerçek key (primary: Llama 3.3 70B)
GEMINI_API_KEY=        # fallback key (Gemini 2.0 Flash, Groq down olunca)
# Production'da MUTLAKA false olmalı — true iken sabit fixture mail döner, gerçek LLM çalışmaz
AI_MOCK_ENABLED=false

# --- Google Maps API ---
GOOGLE_MAPS_API_KEY=

# --- Brevo Transactional Email API (OUTBOUND SEND) ---
# Replaces Gmail SMTP: Render free tier blocks outbound SMTP ports (25/465/587)
# since Sept 2025, so JavaMailSender can't connect from prod. Brevo sends over
# HTTPS:443 (unblocked). Free tier: 300 mails/day.
BREVO_API_KEY=                 # Brevo → SMTP & API → API Keys (starts with xkeysib-)
BREVO_SENDER_EMAIL=            # MUST be a Brevo-verified sender / authenticated domain
BREVO_SENDER_NAME=Akın Coşkun
# BREVO_TIMEOUT_SECONDS=30     # optional, defaults to 30

# --- Gmail IMAP (reply + bounce polling ONLY — NOT sending) ---
# NOTE: Outbound SMTP is GONE (see Brevo above). MAIL_* below is kept ONLY because
# IMAP reply/bounce polling still authenticates with MAIL_USERNAME/MAIL_PASSWORD.
# spring.mail.* (host/port) is commented out in application.yml; MAIL_HOST/MAIL_PORT
# no longer drive sending. MAIL_FROM/MAIL_FROM_NAME still feed the footer signature.
MAIL_USERNAME=akin.tools.outreach@gmail.com
MAIL_PASSWORD=                 # Gmail App Password (16 chars, no spaces) — for IMAP
# from-email / from-name shown in footer signature + List-Unsubscribe mailto.
MAIL_FROM=akin.tools.outreach@gmail.com
MAIL_FROM_NAME=Akın Coşkun
# IMAP host/port for reply + bounce polling (auth reuses MAIL_USERNAME/MAIL_PASSWORD)
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
# ISO date the Gmail outreach account was created — drives warming cap logic
# Format: YYYY-MM-DD
GMAIL_ACCOUNT_CREATED_AT=2026-05-04

# Local/dev only: redirect ALL outgoing mail to this address so real recipients
# are never contacted during testing. MUST be empty/unset in production.
LOCAL_TEST_RECIPIENT_OVERRIDE=

# === SENDER INFO (CAN-SPAM ZORUNLU — production öncesi DOLDUR) ===
# Her giden mail'in footer'ında görünen gerçek fiziksel posta adresi.
# BOŞ bırakılırsa footer'da "Your Address Here" leak olur → CAN-SPAM ihlali.
SENDER_PHYSICAL_ADDRESS=                          # Akın gerçek adres yazsın
# Display name comes from MAIL_FROM_NAME (above), not SENDER_NAME.
SENDER_GITHUB=https://github.com/akincskn
SENDER_PORTFOLIO=https://akin-coskun.web.app

# --- Slack ---
SLACK_WEBHOOK_URL=

# --- Security ---
# Bearer token required on /api/** and /agent/** (Görev 8.1). Zorunlu — production'da
# güçlü, rastgele bir değer (min 32 char) kullan.
API_KEY=
# Random 256-bit hex string → HMAC-signed unsubscribe + tracking pixel tokens
HMAC_SECRET=
# JWT signing secret for service-to-service auth
JWT_SECRET=

# --- N8N ---
# Static API key for N8N → Spring Boot webhook calls
N8N_WEBHOOK_API_KEY=
# URL where Spring Boot API is reachable FROM N8N
# Local: http://host.docker.internal:8080  |  Prod: https://outreach-api.onrender.com
SPRING_API_URL=

# --- Frontend (Next.js Dashboard) ---
# NextAuth v5 secret — generate: openssl rand -base64 32
AUTH_SECRET=
# The publicly reachable URL of this Next.js app
AUTH_URL=http://localhost:3000
# Single admin credentials for the dashboard (Faz 1 — just Akın)
DASHBOARD_USERNAME=akin
DASHBOARD_PASSWORD=
# Spring Boot API base URL (used client-side)
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- CORS ---
# Comma-separated list of allowed frontend origins for the Spring Boot API
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Rate Limiting ---
# Max requests per minute per IP (Spring Boot API)
RATE_LIMIT_RPM=100

# --- Local Dev (Docker Compose) ---
# MailHog SMTP — replaces Gmail in local dev (never burns the real account)
MAILHOG_SMTP_HOST=localhost
MAILHOG_SMTP_PORT=1025
MAILHOG_WEB_PORT=8025
# Local Postgres (overridden in prod by DATABASE_URL)
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=outreach
LOCAL_DB_USER=outreach
LOCAL_DB_PASSWORD=outreach
