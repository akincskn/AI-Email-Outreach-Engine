# ==============================================================
# AI Email Outreach Engine — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or .env to version control.
# ==============================================================

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=

# --- AI Providers ---
GROQ_API_KEY=
GEMINI_API_KEY=

# --- Google Maps API ---
GOOGLE_MAPS_API_KEY=

# --- Gmail SMTP (outreach account) ---
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
# Date the Gmail outreach account was created (ISO, UTC). Used for warming progression.
# Format: YYYY-MM-DD
GMAIL_ACCOUNT_CREATED_AT=

# --- Slack ---
SLACK_WEBHOOK_URL=

# --- Security ---
# Random 256-bit hex string. Used for HMAC-signed unsubscribe & tracking pixel tokens.
HMAC_SECRET=
# JWT signing secret for service-to-service auth
JWT_SECRET=

# --- N8N ---
# Static API key for N8N → Spring Boot webhook calls
N8N_WEBHOOK_API_KEY=

# --- CAN-SPAM Compliance ---
# Physical mailing address shown in every outbound email footer
SENDER_PHYSICAL_ADDRESS=

# --- Frontend (Next.js) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
# Single admin password for the dashboard (Faz 1 — just Akın)
DASHBOARD_PASSWORD=
# Spring Boot API base URL
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- Rate Limiting ---
# Max requests per minute per IP (default 100 in prod, higher in local dev)
RATE_LIMIT_RPM=100

# --- Local Dev (Docker Compose) ---
# MailHog SMTP (replaces Gmail in local dev)
MAILHOG_SMTP_HOST=localhost
MAILHOG_SMTP_PORT=1025
MAILHOG_WEB_PORT=8025
# Local Postgres (overridden in prod by DATABASE_URL)
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=outreach
LOCAL_DB_USER=outreach
LOCAL_DB_PASSWORD=outreach
