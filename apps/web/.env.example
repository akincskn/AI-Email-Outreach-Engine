# ==============================================================
# AI Email Outreach Engine — Web Dashboard env
# Copy to .env.local and fill in. Never commit .env.local.
# ==============================================================

# Spring Boot backend base URL (used by the server-side proxy + server components)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Bearer token for the backend — MUST match apps/api API_KEY.
# Server-only: injected by the /api/proxy route, never shipped to the browser.
API_KEY=

# Dashboard login (single user, Credentials provider)
DASHBOARD_USERNAME=akin
DASHBOARD_PASSWORD=          # production: strong password

# NextAuth v5 session secret (32+ char random string). AUTH_SECRET is the v5 name;
# NEXTAUTH_SECRET is kept as an alias for tooling that still reads the v4 name.
AUTH_SECRET=
NEXTAUTH_SECRET=          # same value as AUTH_SECRET
# v5 auto-detects the host on localhost; set explicitly in production (https://...)
NEXTAUTH_URL=http://localhost:3000
